# 复制为 .env 并填入真实值（.env 勿提交 Git）
# 用法：cp .env.example .env

# === OpenHarness Provider（至少配置一个 profile 对应项）===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 公司统一模型网关（OpenAI-Compatible 示例）
# OPENAI_BASE_URL=https://llm-gateway.company.com/v1
# DEFAULT_MODEL=company-chat

# Moonshot / 其他 Compatible 端点
# MOONSHOT_API_KEY=

# === OpenHarness 运行时 ===
# OPENHARNESS_API_FORMAT=openai
# OPENHARNESS_WEB_SEARCH_URL=https://your-searxng.example/search
# OPENHARNESS_WEB_PROXY=

# === MCP（P2 起）===
# MCP_CONFIG_PATH=./config/mcp/servers.json

# === Gateway（P4 起）===
# GATEWAY_HOST=0.0.0.0
# GATEWAY_PORT=8080
# GATEWAY_API_KEY=change-me-in-prod

# === 审计 / 会话存储（P5 起，可选 Postgres）===
DATABASE_URL=postgresql://harness:harness@localhost:5434/harness_dev

# === 观测（P5 起，可选）===
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=openharness-company-backend

# === ohmo 通道（P4 起，按通道文档填写）===
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
