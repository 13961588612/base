# 复制为 .env 并填入真实值（.env 勿提交 Git）

# === LLM Providers（至少配置一个）===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 可选：本地 Ollama
# OLLAMA_BASE_URL=http://localhost:11434

# === LangSmith 观测（P1 起推荐）===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=python-ai-learning

# === 数据库（P3 起 LangGraph checkpoint / P2 pgvector）===
DATABASE_URL=postgresql://agent:agent@localhost:5433/agent_dev

# === 默认模型（可按项目覆盖）===
# 格式示例：openai:gpt-4o-mini / anthropic:claude-sonnet-4-20250514
DEFAULT_MODEL=openai:gpt-4o-mini
